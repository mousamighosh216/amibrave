# Amibrave — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Required ───────────────────────────────────────────────────────────────

# Google Gemini API key (free tier at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ───────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins for CORS
# Add your GitHub Pages URL here after deploying
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://yourusername.github.io

# Flask environment: development | production
FLASK_ENV=production

# Port (Render sets this automatically)
PORT=5000
